# Mission Control Environment Configuration
# Copy this file to .env.local for local development
# Copy this file to .env.production for production deployment

# OpenClaw workspace root directory
# Development (local): defaults to ../openclaw-workspace (sibling folder)
# Production (server): set to /home/atish/.openclaw or your OpenClaw installation path
OPENCLAW_ROOT=

# OpenClaw Gateway (optional - will be read from openclaw.json if not set)
# OPENCLAW_GATEWAY_PORT=18789
# OPENCLAW_GATEWAY_TOKEN=your-token-here
